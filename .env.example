# Copy this file to `.env` and fill in the keys for the providers you use.
# .env is gitignored. You can also paste keys into the Settings tab in the UI,
# which keeps them in-memory only (unless you click "Save to .env").

# For `caption -p gemini` and `audit -p gemini`.
GEMINI_API_KEY=

# For `caption -p replicate`.
REPLICATE_API_TOKEN=

# Optional: if you run a local Ollama server for `caption -p openai`, set these.
# Defaults match what the Klippbok CLI assumes (localhost:11434, llama3.2-vision).
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2-vision
